APP_NAME=Exam API
PORT=3000
API_PREFIX=api
FRONTEND_URL=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/exam
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_DOMAIN=
COOKIE_SECRET=change-me-cookie-secret
NODE_ENV=development
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOCK_WINDOW_MINUTES=1
AUTH_IP_MAX_ATTEMPTS=5
AUTH_LOGIN_TTL_SECONDS=60
AUTH_LOGIN_LIMIT=10
AUTH_REGISTER_TTL_SECONDS=60
AUTH_REGISTER_LIMIT=10
AUTH_REFRESH_TTL_SECONDS=60
AUTH_REFRESH_LIMIT=10
AUTH_CSRF_TTL_SECONDS=60
AUTH_CSRF_LIMIT=10
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
