{
  "info": {
    "_postman_id": "6b973e80-8cf3-4f68-a01c-8ef39de32fb1",
    "name": "Exam API - Auth Full Test Suite",
    "description": "Full Postman flow for cookie JWT auth, CSRF, refresh rotation, lockout, rate limit and Google OAuth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "A. Basic Flow",
      "item": [
        {
          "name": "A1. Get CSRF Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.environment.set('csrfToken', body.data.csrfToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}api/v1/auth/csrf-token"
          }
        },
        {
          "name": "A2. Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 or 409 if user already exists', () => pm.expect([201, 409]).to.include(pm.response.code));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"fullName\": \"{{fullName}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}api/v1/auth/register"
          }
        },
        {
          "name": "A3. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}api/v1/auth/login"
          }
        },
        {
          "name": "A4. Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Does not expose secrets', () => {",
                  "  pm.expect(body.data).to.not.have.property('passwordHash');",
                  "  pm.expect(body.data).to.not.have.property('refreshTokenHash');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}api/v1/auth/me"
          }
        },
        {
          "name": "A5. Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "url": "{{baseUrl}}api/v1/auth/refresh"
          }
        },
        {
          "name": "A6. Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "url": "{{baseUrl}}api/v1/auth/logout"
          }
        },
        {
          "name": "A7. Me After Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}api/v1/auth/me"
          }
        }
      ]
    },
    {
      "name": "B. CSRF Protection",
      "item": [
        {
          "name": "B1. Login Without CSRF Header",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('403 Forbidden', () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}api/v1/auth/login"
          }
        },
        {
          "name": "B2. Login With Wrong CSRF Header",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('403 Forbidden', () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-Token", "value": "wrong-token" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}api/v1/auth/login"
          }
        }
      ]
    },
    {
      "name": "C. Refresh Rotation",
      "item": [
        {
          "name": "C1. Login Before Rotation Test",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}api/v1/auth/login"
          }
        },
        {
          "name": "C2. Refresh Once",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "url": "{{baseUrl}}api/v1/auth/refresh"
          }
        },
        {
          "name": "C3. Manual Reuse Old Refresh Token",
          "description": "Before running C2, copy the old refreshToken cookie value. After C2 rotates it, replace the current refreshToken cookie with the old value, then run this request. Expected result: 401 and current session revoked.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 Unauthorized on reused old refresh token', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "url": "{{baseUrl}}api/v1/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "D. Login Failures And Lockout",
      "item": [
        {
          "name": "D1. Wrong Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{wrongPassword}}\"\n}"
            },
            "url": "{{baseUrl}}api/v1/auth/login"
          }
        },
        {
          "name": "D2. Same Wrong Password x5",
          "description": "Use Collection Runner with 5 iterations inside 1 minute to trigger email lock.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{wrongPassword}}\"\n}"
            },
            "url": "{{baseUrl}}api/v1/auth/login"
          }
        },
        {
          "name": "D3. Correct Password While Email Locked",
          "description": "After D2 reaches the configured email threshold, even the correct password should still return the generic 401 response until lockUntil expires.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 Unauthorized while email is locked', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}api/v1/auth/login"
          }
        }
      ]
    },
    {
      "name": "E. Rate Limit",
      "item": [
        {
          "name": "E1. Login Rate Limit",
          "description": "Run this request more than 10 times within 1 minute. Expected: later requests return 429.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{wrongPassword}}\"\n}"
            },
            "url": "{{baseUrl}}api/v1/auth/login"
          }
        },
        {
          "name": "E2. Register Rate Limit",
          "description": "Run with several unique emails by editing email variable each time or using a CSV data file. Send more than 10 requests within 1 minute. Expected: later requests return 429.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{registerRateEmail}}\",\n  \"fullName\": \"{{fullName}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}api/v1/auth/register"
          }
        },
        {
          "name": "E3. Refresh Rate Limit",
          "description": "Login first, then run this more than 10 times within 1 minute. Expected: later requests return 429.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-CSRF-Token", "value": "{{csrfToken}}" }
            ],
            "url": "{{baseUrl}}api/v1/auth/refresh"
          }
        },
        {
          "name": "E4. CSRF Token Rate Limit",
          "description": "Run this more than 10 times within 1 minute. Expected: later requests return 429.",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}api/v1/auth/csrf-token"
          }
        }
      ]
    },
    {
      "name": "F. Google OAuth",
      "item": [
        {
          "name": "F1. Start Google OAuth",
          "description": "This starts the redirect flow and sets signed oauthState cookie. In Postman, disable automatic redirects if you want to inspect the 302 response and Location header.",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}api/v1/auth/google"
          }
        },
        {
          "name": "F2. Google Callback Invalid State",
          "description": "This is the Postman-testable negative case. Expected: redirect to frontend login with google_auth_failed.",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}api/v1/auth/google/callback?state=wrong-state"
          }
        }
      ]
    }
  ]
}
